    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.orderId) {",
                  "  pm.collectionVariables.set('orderId', json.data.orderId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Suresh\",\n  \"phoneNumber\": \"9876543210\",\n  \"items\": [\n    {\n      \"productName\": \"Wireless Mouse\",\n      \"quantity\": 2,\n      \"price\": 499\n    },\n    {\n      \"productName\": \"Mechanical Keyboard\",\n      \"quantity\": 1,\n      \"price\": 1499\n    }\n  ],\n  \"paymentStatus\": \"PAID\",\n  \"orderStatus\": \"PLACED\"\n}"
            },
            "url": {
              "raw": "{{apiBaseUrl}}/orders/create-order",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "orders",
                "create-order"
              ]
            }
          },
          "response": []
